{
  "name": "hungtran-pm",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12.0 <25"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "migrate:programs": "node scripts/migrate-program-ids.js",
    "migrate:programs:dry": "node scripts/migrate-program-ids.js --dry-run",
    "migrate:lessons": "node scripts/migrate-lessons-subcollection.js",
    "migrate:lessons:dry": "node scripts/migrate-lessons-subcollection.js --dry-run",
    "migrate:feedback-index": "node scripts/migrate-student-feedback-index.js",
    "migrate:feedback-index:dry": "node scripts/migrate-student-feedback-index.js --dry-run",
    "audit:curriculum": "node scripts/audit-curriculum-collections.js",
    "audit:security": "npm run audit:security:full",
    "audit:security:full": "npm audit",
    "audit:security:gate": "npm audit --audit-level=high",
    "ci": "npm test && npm run test:rules && npm run build && npm run audit:security:gate",
    "verify": "npm test && npm run build",
    "inspect:lessons": "node scripts/inspect-program-lessons.js",
    "deploy:firestore": "firebase deploy --only firestore:rules,firestore:indexes",
    "deploy:firebase": "firebase deploy --only firestore:rules,firestore:indexes,storage",
    "test": "vitest run",
    "test:rules": "firebase emulators:exec --only firestore \"vitest run --config vitest.rules.config.js\"",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@uiw/react-codemirror": "^4.25.10",
    "dompurify": "^3.4.11",
    "firebase": "^12.15.0",
    "lucide-react": "^1.22.0",
    "marked": "^18.0.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.18.1",
    "recharts": "^3.9.0"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@tailwindcss/vite": "^4.3.2",
    "@vitejs/plugin-react": "^6.0.3",
    "firebase-admin": "^14.1.0",
    "firebase-tools": "^15.22.3",
    "happy-dom": "^20.10.6",
    "tailwindcss": "^4.3.2",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
