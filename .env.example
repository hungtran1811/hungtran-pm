# Firebase Web (bắt buộc)
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
# Lấy từ Firebase Console → Project settings → Your apps
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id

# Nộp file code lưu trên Firestore (Spark plan). Không cần bật Firebase Storage.
# Deploy rules: npx firebase deploy --only firestore:rules,firestore:indexes

# Cloudinary — upload ảnh bài giảng (bắt buộc nếu dùng editor ảnh)
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_unsigned_upload_preset
VITE_CLOUDINARY_CURRICULUM_FOLDER=curriculum

# Domain công khai dùng cho link chia sẻ (link học sinh + link trình chiếu).
# Bỏ trống khi chạy localhost (sẽ tự dùng origin hiện tại). Khi deploy đặt:
# VITE_PUBLIC_BASE_URL=https://hungtranpm.netlify.app
VITE_PUBLIC_BASE_URL=
