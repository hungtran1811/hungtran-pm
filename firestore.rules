rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function normalizedEmail() {
      return request.auth.token.email.lower();
    }

    function adminDoc() {
      return get(/databases/$(database)/documents/admins/$(normalizedEmail()));
    }

    function isAdmin() {
      return isSignedIn()
        && request.auth.token.email != null
        && exists(/databases/$(database)/documents/admins/$(normalizedEmail()))
        && adminDoc().data.active == true;
    }

    function classDoc(classId) {
      return get(/databases/$(database)/documents/classes/$(classId));
    }

    function studentDoc(studentId) {
      return get(/databases/$(database)/documents/students/$(studentId));
    }

    function curriculumProgramDoc(programId) {
      return get(/databases/$(database)/documents/curriculumPrograms/$(programId));
    }

    function isQuizMode(mode) {
      return mode == 'official_quiz' || mode == 'practice_quiz';
    }

    function isValidStage(stage) {
      return stage == 'Ý tưởng'
        || stage == 'Lên kế hoạch'
        || stage == 'Thiết kế'
        || stage == 'Xây dựng chức năng'
        || stage == 'Kiểm thử'
        || stage == 'Hoàn thiện'
        || stage == 'Thuyết trình / Nộp sản phẩm';
    }

    function isValidStatus(status) {
      return status == 'Chưa bắt đầu'
        || status == 'Đang làm'
        || status == 'Cần hỗ trợ'
        || status == 'Gần hoàn thành'
        || status == 'Hoàn thành';
    }

    function isValidProgress(progress) {
      return progress is int && progress >= 0 && progress <= 100;
    }

    function isQuizSessionNumber(sessionNumber) {
      return sessionNumber is int && sessionNumber >= 1 && sessionNumber <= 50;
    }

    function isOpenClass(classId) {
      return classId is string
        && exists(/databases/$(database)/documents/classes/$(classId))
        && classDoc(classId).data.status == 'active'
        && classDoc(classId).data.hidden == false;
    }

    function isActiveStudentInClass(studentId, classCode) {
      return studentId is string
        && exists(/databases/$(database)/documents/students/$(studentId))
        && studentDoc(studentId).data.active == true
        && studentDoc(studentId).data.classId == classCode;
    }

    function isActiveProgram(programId) {
      return programId is string
        && exists(/databases/$(database)/documents/curriculumPrograms/$(programId))
        && curriculumProgramDoc(programId).data.active == true;
    }

    function quizPublicConfigExists(programId, sessionNumber) {
      return programId is string
        && programId.size() > 0
        && isQuizSessionNumber(sessionNumber);
    }

    function matchesQuizAttemptId(attemptId, classCode, studentId, sessionNumber, quizMode) {
      return classCode is string
        && studentId is string
        && isQuizMode(quizMode)
        && attemptId is string
        && attemptId.matches('^' + classCode + '__' + studentId + '__[0-9]+(__practice)?$');
    }

    function isQuizAnswerMap(answers, questionCount) {
      return answers is map
        && questionCount is int
        && questionCount > 0
        && answers.keys().size() == questionCount;
    }

    function isQuizQuestionIdList(questionIds, questionCount) {
      return questionIds is list
        && questionCount is int
        && questionCount > 0
        && questionIds.size() == questionCount;
    }

    function isQuizStartedForClass(classCode, sessionNumber) {
      return isOpenClass(classCode)
        && isQuizSessionNumber(sessionNumber)
        && classDoc(classCode).data.quizStatus == 'started'
        && classDoc(classCode).data.activeQuizSessionNumber == sessionNumber;
    }

    function isValidPublicReportCreate() {
      return request.resource.data.keys().hasOnly([
          'classId',
          'classCode',
          'studentId',
          'studentName',
          'projectName',
          'progressPercent',
          'stage',
          'status',
          'doneToday',
          'nextGoal',
          'difficulties',
          'submittedAt',
          'submittedDateKey',
          'source',
          'createdAt'
        ])
        && request.resource.data.keys().hasAll([
          'classId',
          'classCode',
          'studentId',
          'studentName',
          'projectName',
          'progressPercent',
          'stage',
          'status',
          'doneToday',
          'nextGoal',
          'difficulties',
          'submittedAt',
          'submittedDateKey',
          'source',
          'createdAt'
        ])
        && request.resource.data.classId == request.resource.data.classCode
        && isOpenClass(request.resource.data.classCode)
        && isActiveStudentInClass(request.resource.data.studentId, request.resource.data.classCode)
        && studentDoc(request.resource.data.studentId).data.fullName == request.resource.data.studentName
        && studentDoc(request.resource.data.studentId).data.projectName == request.resource.data.projectName
        && isValidProgress(request.resource.data.progressPercent)
        && isValidStage(request.resource.data.stage)
        && isValidStatus(request.resource.data.status)
        && request.resource.data.doneToday is string
        && request.resource.data.doneToday.size() >= 10
        && request.resource.data.doneToday.size() <= 2000
        && request.resource.data.nextGoal is string
        && request.resource.data.nextGoal.size() >= 10
        && request.resource.data.nextGoal.size() <= 2000
        && request.resource.data.difficulties is string
        && request.resource.data.difficulties.size() <= 2000
        && (request.resource.data.status != 'Cần hỗ trợ' || request.resource.data.difficulties.size() >= 15)
        && (request.resource.data.status != 'Hoàn thành' || request.resource.data.progressPercent == 100)
        && request.resource.data.submittedAt == request.time
        && request.resource.data.createdAt == request.time
        && request.resource.data.submittedDateKey is string
        && request.resource.data.submittedDateKey.size() == 10
        && request.resource.data.source == 'student-form';
    }

    function isValidPublicStudentSnapshotUpdate(studentId) {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'currentProgressPercent',
          'currentStage',
          'currentStatus',
          'currentDifficulties',
          'lastReportedAt',
          'latestReportId',
          'progressStalledCount',
          'updatedAt'
        ])
        && resource.data.active == true
        && resource.data.progressStalledCount is int
        && isOpenClass(resource.data.classId)
        && isValidProgress(request.resource.data.currentProgressPercent)
        && isValidStage(request.resource.data.currentStage)
        && isValidStatus(request.resource.data.currentStatus)
        && request.resource.data.currentDifficulties is string
        && request.resource.data.currentDifficulties.size() <= 2000
        && request.resource.data.lastReportedAt == request.time
        && request.resource.data.updatedAt == request.time
        && request.resource.data.latestReportId is string
        && request.resource.data.latestReportId.size() > 0
        && request.resource.data.progressStalledCount is int
        && request.resource.data.progressStalledCount >= 0
        && request.resource.data.progressStalledCount <= resource.data.progressStalledCount + 1
        && getAfter(/databases/$(database)/documents/reports/$(request.resource.data.latestReportId)).data != null
        && getAfter(/databases/$(database)/documents/reports/$(request.resource.data.latestReportId)).data.studentId == studentId
        && getAfter(/databases/$(database)/documents/reports/$(request.resource.data.latestReportId)).data.classCode == resource.data.classId
        && getAfter(/databases/$(database)/documents/reports/$(request.resource.data.latestReportId)).data.status == request.resource.data.currentStatus
        && getAfter(/databases/$(database)/documents/reports/$(request.resource.data.latestReportId)).data.stage == request.resource.data.currentStage
        && getAfter(/databases/$(database)/documents/reports/$(request.resource.data.latestReportId)).data.progressPercent == request.resource.data.currentProgressPercent
        && getAfter(/databases/$(database)/documents/reports/$(request.resource.data.latestReportId)).data.difficulties == request.resource.data.currentDifficulties
        && getAfter(/databases/$(database)/documents/reports/$(request.resource.data.latestReportId)).data.submittedAt == request.resource.data.lastReportedAt;
    }

    function isReadableQuizAttemptState(attemptId, data) {
      return data != null
        && data.classCode is string
        && data.studentId is string
        && (data.quizMode == null || isQuizMode(data.quizMode))
        && isQuizSessionNumber(data.sessionNumber)
        && isOpenClass(data.classCode)
        && isActiveStudentInClass(data.studentId, data.classCode)
        && matchesQuizAttemptId(
          attemptId,
          data.classCode,
          data.studentId,
          data.sessionNumber,
          data.quizMode == 'practice_quiz' ? 'practice_quiz' : 'official_quiz'
        );
    }

    function isValidQuizAttemptCreate(attemptId) {
      return request.resource.data.keys().hasOnly([
          'classCode',
          'className',
          'studentId',
          'studentName',
          'curriculumProgramId',
          'subject',
          'level',
          'bankId',
          'sessionNumber',
          'quizMode',
          'quizTitle',
          'questionCount',
          'questionIds',
          'answers',
          'status',
          'submissionCount',
          'submittedAt',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.keys().hasAll([
          'classCode',
          'className',
          'studentId',
          'studentName',
          'curriculumProgramId',
          'subject',
          'level',
          'bankId',
          'sessionNumber',
          'quizMode',
          'quizTitle',
          'questionCount',
          'questionIds',
          'answers',
          'status',
          'submissionCount',
          'submittedAt',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.classCode is string
        && request.resource.data.className is string
        && request.resource.data.studentId is string
        && request.resource.data.studentName is string
        && request.resource.data.curriculumProgramId is string
        && request.resource.data.subject is string
        && request.resource.data.level is string
        && request.resource.data.bankId is string
        && isQuizMode(request.resource.data.quizMode)
        && request.resource.data.quizTitle is string
        && request.resource.data.questionCount is int
        && isQuizSessionNumber(request.resource.data.sessionNumber)
        && matchesQuizAttemptId(
          attemptId,
          request.resource.data.classCode,
          request.resource.data.studentId,
          request.resource.data.sessionNumber,
          request.resource.data.quizMode
        )
        && isOpenClass(request.resource.data.classCode)
        && isQuizStartedForClass(request.resource.data.classCode, request.resource.data.sessionNumber)
        && isActiveStudentInClass(request.resource.data.studentId, request.resource.data.classCode)
        && request.resource.data.className == classDoc(request.resource.data.classCode).data.className
        && request.resource.data.studentName == studentDoc(request.resource.data.studentId).data.fullName
        && request.resource.data.curriculumProgramId == classDoc(request.resource.data.classCode).data.curriculumProgramId
        && request.resource.data.sessionNumber == classDoc(request.resource.data.classCode).data.curriculumCurrentSession
        && quizPublicConfigExists(request.resource.data.curriculumProgramId, request.resource.data.sessionNumber)
        && request.resource.data.questionCount <= 10
        && isQuizQuestionIdList(request.resource.data.questionIds, request.resource.data.questionCount)
        && isQuizAnswerMap(request.resource.data.answers, request.resource.data.questionCount)
        && request.resource.data.status == 'submitted'
        && request.resource.data.submissionCount == 1
        && request.resource.data.submittedAt == request.time
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;
    }

    function isValidQuizAttemptUpdate(attemptId) {
      return (resource.data.status == 'reopened' || resource.data.quizMode == 'practice_quiz')
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'answers',
          'subject',
          'level',
          'bankId',
          'status',
          'submissionCount',
          'submittedAt',
          'updatedAt'
        ])
        && matchesQuizAttemptId(attemptId, resource.data.classCode, resource.data.studentId, resource.data.sessionNumber, resource.data.quizMode)
        && request.resource.data.classCode == resource.data.classCode
        && request.resource.data.className == resource.data.className
        && request.resource.data.studentId == resource.data.studentId
        && request.resource.data.studentName == resource.data.studentName
        && request.resource.data.curriculumProgramId == resource.data.curriculumProgramId
        && request.resource.data.subject is string
        && request.resource.data.level is string
        && request.resource.data.bankId is string
        && (!resource.data.keys().hasAny(['subject']) || request.resource.data.subject == resource.data.subject)
        && (!resource.data.keys().hasAny(['level']) || request.resource.data.level == resource.data.level)
        && (!resource.data.keys().hasAny(['bankId']) || request.resource.data.bankId == resource.data.bankId)
        && request.resource.data.sessionNumber == resource.data.sessionNumber
        && request.resource.data.quizMode == resource.data.quizMode
        && request.resource.data.quizTitle == resource.data.quizTitle
        && request.resource.data.questionCount == resource.data.questionCount
        && request.resource.data.questionIds == resource.data.questionIds
        && isOpenClass(resource.data.classCode)
        && isActiveStudentInClass(resource.data.studentId, resource.data.classCode)
        && isQuizAnswerMap(request.resource.data.answers, request.resource.data.questionCount)
        && request.resource.data.status == 'submitted'
        && request.resource.data.submissionCount == resource.data.submissionCount + 1
        && request.resource.data.submittedAt == request.time
        && request.resource.data.updatedAt == request.time;
    }

    function isValidQuizAttemptStateCreate(attemptId) {
      return request.resource.data.keys().hasOnly([
          'classCode',
          'studentId',
          'subject',
          'level',
          'bankId',
          'sessionNumber',
          'quizMode',
          'status',
          'submissionCount',
          'submittedAt',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.keys().hasAll([
          'classCode',
          'studentId',
          'subject',
          'level',
          'bankId',
          'sessionNumber',
          'quizMode',
          'status',
          'submissionCount',
          'submittedAt',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.classCode is string
        && request.resource.data.studentId is string
        && request.resource.data.subject is string
        && request.resource.data.level is string
        && request.resource.data.bankId is string
        && isQuizMode(request.resource.data.quizMode)
        && isQuizSessionNumber(request.resource.data.sessionNumber)
        && matchesQuizAttemptId(
          attemptId,
          request.resource.data.classCode,
          request.resource.data.studentId,
          request.resource.data.sessionNumber,
          request.resource.data.quizMode
        )
        && isOpenClass(request.resource.data.classCode)
        && isQuizStartedForClass(request.resource.data.classCode, request.resource.data.sessionNumber)
        && isActiveStudentInClass(request.resource.data.studentId, request.resource.data.classCode)
        && request.resource.data.sessionNumber == classDoc(request.resource.data.classCode).data.curriculumCurrentSession
        && quizPublicConfigExists(classDoc(request.resource.data.classCode).data.curriculumProgramId, request.resource.data.sessionNumber)
        && request.resource.data.status == 'submitted'
        && request.resource.data.submissionCount == 1
        && request.resource.data.submittedAt == request.time
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;
    }

    function isValidQuizAttemptStateUpdate(attemptId) {
      return (resource.data.status == 'reopened' || resource.data.quizMode == 'practice_quiz')
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'status',
          'subject',
          'level',
          'bankId',
          'submissionCount',
          'submittedAt',
          'updatedAt'
        ])
        && matchesQuizAttemptId(attemptId, resource.data.classCode, resource.data.studentId, resource.data.sessionNumber, resource.data.quizMode)
        && request.resource.data.classCode == resource.data.classCode
        && request.resource.data.studentId == resource.data.studentId
        && request.resource.data.subject is string
        && request.resource.data.level is string
        && request.resource.data.bankId is string
        && (!resource.data.keys().hasAny(['subject']) || request.resource.data.subject == resource.data.subject)
        && (!resource.data.keys().hasAny(['level']) || request.resource.data.level == resource.data.level)
        && (!resource.data.keys().hasAny(['bankId']) || request.resource.data.bankId == resource.data.bankId)
        && request.resource.data.sessionNumber == resource.data.sessionNumber
        && request.resource.data.quizMode == resource.data.quizMode
        && isOpenClass(resource.data.classCode)
        && isActiveStudentInClass(resource.data.studentId, resource.data.classCode)
        && request.resource.data.status == 'submitted'
        && request.resource.data.submissionCount == resource.data.submissionCount + 1
        && request.resource.data.submittedAt == request.time
        && request.resource.data.updatedAt == request.time;
    }

    function isValidQuizAttemptSubmissionCreate(attemptSubmissionId) {
      return request.resource.data.keys().hasOnly([
          'attemptId',
          'classCode',
          'studentId',
          'subject',
          'level',
          'bankId',
          'sessionNumber',
          'quizMode',
          'submissionNumber',
          'questionCount',
          'questionIds',
          'answers',
          'submittedAt',
          'createdAt'
        ])
        && request.resource.data.keys().hasAll([
          'attemptId',
          'classCode',
          'studentId',
          'subject',
          'level',
          'bankId',
          'sessionNumber',
          'quizMode',
          'submissionNumber',
          'questionCount',
          'questionIds',
          'answers',
          'submittedAt',
          'createdAt'
        ])
        && request.resource.data.attemptId is string
        && request.resource.data.classCode is string
        && request.resource.data.studentId is string
        && request.resource.data.subject is string
        && request.resource.data.level is string
        && request.resource.data.bankId is string
        && isQuizMode(request.resource.data.quizMode)
        && request.resource.data.submissionNumber is int
        && request.resource.data.submissionNumber > 0
        && request.resource.data.questionCount is int
        && request.resource.data.questionCount > 0
        && request.resource.data.questionCount <= 10
        && isQuizSessionNumber(request.resource.data.sessionNumber)
        && matchesQuizAttemptId(
          request.resource.data.attemptId,
          request.resource.data.classCode,
          request.resource.data.studentId,
          request.resource.data.sessionNumber,
          request.resource.data.quizMode
        )
        && attemptSubmissionId == request.resource.data.attemptId + '__submission__' + request.resource.data.submissionNumber
        && isQuizQuestionIdList(request.resource.data.questionIds, request.resource.data.questionCount)
        && isQuizAnswerMap(request.resource.data.answers, request.resource.data.questionCount)
        && getAfter(/databases/$(database)/documents/quizAttempts/$(request.resource.data.attemptId)).data != null
        && getAfter(/databases/$(database)/documents/quizAttemptStates/$(request.resource.data.attemptId)).data != null
        && request.resource.data.classCode == getAfter(/databases/$(database)/documents/quizAttempts/$(request.resource.data.attemptId)).data.classCode
        && request.resource.data.studentId == getAfter(/databases/$(database)/documents/quizAttempts/$(request.resource.data.attemptId)).data.studentId
        && request.resource.data.sessionNumber == getAfter(/databases/$(database)/documents/quizAttempts/$(request.resource.data.attemptId)).data.sessionNumber
        && request.resource.data.quizMode == getAfter(/databases/$(database)/documents/quizAttempts/$(request.resource.data.attemptId)).data.quizMode
        && request.resource.data.questionCount == getAfter(/databases/$(database)/documents/quizAttempts/$(request.resource.data.attemptId)).data.questionCount
        && request.resource.data.questionIds == getAfter(/databases/$(database)/documents/quizAttempts/$(request.resource.data.attemptId)).data.questionIds
        && request.resource.data.answers == getAfter(/databases/$(database)/documents/quizAttempts/$(request.resource.data.attemptId)).data.answers
        && request.resource.data.submittedAt == request.time
        && request.resource.data.createdAt == request.time
        && (
          (
            !exists(/databases/$(database)/documents/quizAttemptStates/$(request.resource.data.attemptId))
            && request.resource.data.submissionNumber == 1
            && getAfter(/databases/$(database)/documents/quizAttemptStates/$(request.resource.data.attemptId)).data.status == 'submitted'
            && getAfter(/databases/$(database)/documents/quizAttemptStates/$(request.resource.data.attemptId)).data.submissionCount == 1
          )
          || (
            exists(/databases/$(database)/documents/quizAttemptStates/$(request.resource.data.attemptId))
            && (
              get(/databases/$(database)/documents/quizAttemptStates/$(request.resource.data.attemptId)).data.status == 'reopened'
              || get(/databases/$(database)/documents/quizAttemptStates/$(request.resource.data.attemptId)).data.quizMode == 'practice_quiz'
            )
            && getAfter(/databases/$(database)/documents/quizAttemptStates/$(request.resource.data.attemptId)).data.status == 'submitted'
            && getAfter(/databases/$(database)/documents/quizAttemptStates/$(request.resource.data.attemptId)).data.submissionCount
              == get(/databases/$(database)/documents/quizAttemptStates/$(request.resource.data.attemptId)).data.submissionCount + 1
            && request.resource.data.submissionNumber
              == getAfter(/databases/$(database)/documents/quizAttemptStates/$(request.resource.data.attemptId)).data.submissionCount
          )
        );
    }

    match /admins/{adminId} {
      allow read: if isSignedIn() && adminId == normalizedEmail();
      allow write: if false;
    }

    match /classes/{classId} {
      allow read: if isAdmin() || (resource.data.status == 'active' && resource.data.hidden == false);
      allow write: if isAdmin();
    }

    match /curriculumPrograms/{programId} {
      allow read: if isAdmin() || resource.data.active == true;
      allow write: if isAdmin();
    }

    match /curriculumPrograms/{programId}/quizConfigs/{quizId} {
      allow read, write: if isAdmin();
    }

    match /curriculumPrograms/{programId}/quizPublicConfigs/{quizId} {
      allow read: if isAdmin() || isActiveProgram(programId);
      allow write: if isAdmin();
    }

    match /quizQuestionBanks/{bankId} {
      allow read, write: if isAdmin();
    }

    match /quizPublicQuestionBanks/{bankId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /students/{studentId} {
      allow read: if isAdmin() || resource.data.active == true;
      allow create: if isAdmin();
      allow update: if isAdmin() || isValidPublicStudentSnapshotUpdate(studentId);
      allow delete: if isAdmin();
    }

    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isAdmin() || isValidPublicReportCreate();
      allow update: if false;
      allow delete: if isAdmin();
    }

    match /quizAttempts/{attemptId} {
      allow read: if isAdmin();
      allow create: if isAdmin() || isValidQuizAttemptCreate(attemptId);
      allow update: if isAdmin() || isValidQuizAttemptUpdate(attemptId);
      allow delete: if isAdmin();
    }

    match /quizAttemptStates/{attemptId} {
      allow read: if isAdmin() || resource == null || isReadableQuizAttemptState(attemptId, resource.data);
      allow create: if isAdmin() || isValidQuizAttemptStateCreate(attemptId);
      allow update: if isAdmin() || isValidQuizAttemptStateUpdate(attemptId);
      allow delete: if isAdmin();
    }

    match /quizAttemptSubmissions/{attemptSubmissionId} {
      allow read: if isAdmin();
      allow create: if isAdmin() || isValidQuizAttemptSubmissionCreate(attemptSubmissionId);
      allow update: if false;
      allow delete: if isAdmin();
    }
  }
}
