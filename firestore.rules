rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function normalizedEmail() {
      return lower(request.auth.token.email);
    }

    function adminDoc() {
      return get(/databases/$(database)/documents/admins/$(normalizedEmail()));
    }

    function isAdmin() {
      return isSignedIn()
        && request.auth.token.email != null
        && exists(/databases/$(database)/documents/admins/$(normalizedEmail()))
        && adminDoc().data.active == true;
    }

    match /admins/{adminId} {
      allow read: if isSignedIn() && adminId == normalizedEmail();
      allow write: if false;
    }

    match /classes/{classId} {
      allow read, write: if isAdmin();
    }

    match /students/{studentId} {
      allow read, write: if isAdmin();
    }

    match /reports/{reportId} {
      allow read: if isAdmin();
      allow write: if false;
    }
  }
}
