rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function normalizedEmail() {
      return request.auth.token.email.lower();
    }

    function adminDoc() {
      return get(/databases/$(database)/documents/admins/$(normalizedEmail()));
    }

    function isAdminActive(active) {
      return active == true || active == 'true';
    }

    function isAdmin() {
      return isSignedIn()
        && request.auth.token.email != null
        && exists(/databases/$(database)/documents/admins/$(normalizedEmail()))
        && isAdminActive(adminDoc().data.active);
    }

    function classDoc(classId) {
      return get(/databases/$(database)/documents/classes/$(classId));
    }

    function studentDoc(studentId) {
      return get(/databases/$(database)/documents/students/$(studentId));
    }

    function curriculumProgramDoc(programId) {
      return get(/databases/$(database)/documents/curriculumPrograms/$(programId));
    }

    function isValidStage(stage) {
      return stage == 'Phân tích vấn đề'
        || stage == 'Thiết kế giải pháp'
        || stage == 'Xây dựng sản phẩm'
        || stage == 'Kiểm thử sản phẩm'
        || stage == 'Bảo trì & cải tiến';
    }

    function isValidStatus(status) {
      return status == 'Chưa bắt đầu'
        || status == 'Đang làm'
        || status == 'Cần hỗ trợ'
        || status == 'Gần hoàn thành'
        || status == 'Hoàn thành';
    }

    function isValidProgress(progress) {
      return progress is int && progress >= 0 && progress <= 100;
    }

    function isOpenClass(classId) {
      return classId is string
        && exists(/databases/$(database)/documents/classes/$(classId))
        && classDoc(classId).data.status == 'active'
        && classDoc(classId).data.hidden == false;
    }

    function isActiveStudentInClass(studentId, classCode) {
      return studentId is string
        && exists(/databases/$(database)/documents/students/$(studentId))
        && studentDoc(studentId).data.active == true
        && studentDoc(studentId).data.classId == classCode;
    }

    function isActiveProgram(programId) {
      return programId is string
        && exists(/databases/$(database)/documents/curriculumPrograms/$(programId))
        && curriculumProgramDoc(programId).data.active == true;
    }

    function isValidOptionalProjectLink(value) {
      return value is string
        && value.size() <= 500
        && (value == '' || value.matches('^https://.+$'));
    }

    function isValidPublicReportCreate() {
      return request.resource.data.keys().hasOnly([
          'classId', 'classCode', 'studentId', 'studentName', 'projectName',
          'progressPercent', 'stage', 'status', 'doneToday', 'nextGoal',
          'difficulties', 'projectGithubUrl', 'projectCanvaUrl',
          'submittedAt', 'submittedDateKey', 'source', 'createdAt'
        ])
        && request.resource.data.classId == request.resource.data.classCode
        && isOpenClass(request.resource.data.classCode)
        && isActiveStudentInClass(request.resource.data.studentId, request.resource.data.classCode)
        && studentDoc(request.resource.data.studentId).data.fullName == request.resource.data.studentName
        && studentDoc(request.resource.data.studentId).data.projectName == request.resource.data.projectName
        && isValidProgress(request.resource.data.progressPercent)
        && isValidStage(request.resource.data.stage)
        && isValidStatus(request.resource.data.status)
        && request.resource.data.doneToday is string
        && request.resource.data.doneToday.size() >= 10
        && request.resource.data.nextGoal is string
        && request.resource.data.nextGoal.size() >= 10
        && request.resource.data.difficulties is string
        && isValidOptionalProjectLink(request.resource.data.projectGithubUrl)
        && isValidOptionalProjectLink(request.resource.data.projectCanvaUrl)
        && (request.resource.data.status != 'Cần hỗ trợ' || request.resource.data.difficulties.size() >= 15)
        && (request.resource.data.status != 'Hoàn thành' || request.resource.data.progressPercent == 100)
        && request.resource.data.submittedAt == request.time
        && request.resource.data.createdAt == request.time
        && request.resource.data.source == 'student-form';
    }

    function isKnowledgeFeedbackId(feedbackId, data) {
      return feedbackId is string
        && data.feedbackId == feedbackId
        && data.classCode is string
        && data.studentId is string
        && data.lessonId is string
        && feedbackId == data.classCode + '__' + data.studentId + '__' + data.lessonId;
    }

    function isOpenKnowledgeFeedbackTarget(data) {
      return data.curriculumProgramId is string
        && data.curriculumProgramId.size() > 0
        && isActiveProgram(data.curriculumProgramId)
        && (
          !classDoc(data.classCode).data.keys().hasAny(['curriculumProgramId'])
          || classDoc(data.classCode).data.curriculumProgramId == ''
          || classDoc(data.classCode).data.curriculumProgramId == data.curriculumProgramId
        )
        && data.sessionNumber is number
        && data.sessionNumber >= 1
        && data.sessionNumber <= 50
        && (
          !classDoc(data.classCode).data.keys().hasAny(['curriculumCurrentSession'])
          || classDoc(data.classCode).data.curriculumCurrentSession <= 0
          || classDoc(data.classCode).data.curriculumPhase == 'final'
          || data.sessionNumber <= classDoc(data.classCode).data.curriculumCurrentSession
        );
    }

    function knowledgeReportAfter(feedbackId) {
      return getAfter(/databases/$(database)/documents/knowledgeReports/$(feedbackId));
    }

    function hasMatchingKnowledgeReportAfter(feedbackId, data) {
      return knowledgeReportAfter(feedbackId).data != null
        && knowledgeReportAfter(feedbackId).data.feedbackId == data.feedbackId
        && knowledgeReportAfter(feedbackId).data.classCode == data.classCode
        && knowledgeReportAfter(feedbackId).data.studentId == data.studentId
        && knowledgeReportAfter(feedbackId).data.submittedAt == data.submittedAt;
    }

    function isValidPublicKnowledgeReportCreate(reportId) {
      return isKnowledgeFeedbackId(reportId, request.resource.data)
        && isOpenClass(request.resource.data.classCode)
        && isActiveStudentInClass(request.resource.data.studentId, request.resource.data.classCode)
        && studentDoc(request.resource.data.studentId).data.fullName == request.resource.data.studentName
        && isOpenKnowledgeFeedbackTarget(request.resource.data)
        && request.resource.data.understoodTopics is string
        && request.resource.data.understoodTopics.size() >= 5
        && request.resource.data.unclearTopics is string
        && request.resource.data.unclearTopics.size() >= 5
        && request.resource.data.understandingLevel is number
        && request.resource.data.understandingLevel >= 1
        && request.resource.data.understandingLevel <= 5
        && request.resource.data.submittedAt == request.time
        && request.resource.data.createdAt == request.time;
    }

    function isReadablePublicKnowledgeReportReceipt(receiptId, data) {
      return data != null
        && isKnowledgeFeedbackId(receiptId, data)
        && isOpenClass(data.classCode)
        && isActiveStudentInClass(data.studentId, data.classCode);
    }

    function isKnowledgeReceiptIdShape(receiptId) {
      return receiptId is string
        && receiptId.size() > 0
        && receiptId.matches('^.+__.+__.+$');
    }

    function isValidPublicKnowledgeReportReceiptCreate(receiptId) {
      return isKnowledgeFeedbackId(receiptId, request.resource.data)
        && isOpenClass(request.resource.data.classCode)
        && isActiveStudentInClass(request.resource.data.studentId, request.resource.data.classCode)
        && isOpenKnowledgeFeedbackTarget(request.resource.data)
        && request.resource.data.submittedAt == request.time
        && request.resource.data.createdAt == request.time
        && hasMatchingKnowledgeReportAfter(receiptId, request.resource.data);
    }

    function isQuizAttemptId(attemptId, data) {
      return attemptId is string
        && data.attemptId == attemptId
        && data.classCode is string
        && data.studentId is string
        && data.lessonId is string
        && attemptId == data.classCode + '__' + data.studentId + '__' + data.lessonId;
    }

    function quizBankId(data) {
      return data.programId + '__' + data.lessonId;
    }

    function quizPublicBankEnabled(programId, lessonId) {
      let bankId = programId + '__' + lessonId;
      return exists(/databases/$(database)/documents/quizPublicQuestionBanks/$(bankId))
        && get(/databases/$(database)/documents/quizPublicQuestionBanks/$(bankId)).data.enabled == true;
    }

    function quizPublicBankEnabledAny(programId, lessonId) {
      return quizPublicBankEnabled(programId, lessonId)
        || (programId == 'python-basic' && quizPublicBankEnabled('python-app-basic', lessonId))
        || (programId == 'python-app-basic' && quizPublicBankEnabled('python-basic', lessonId))
        || (programId == 'python-advanced' && quizPublicBankEnabled('python-app-advanced', lessonId))
        || (programId == 'python-app-advanced' && quizPublicBankEnabled('python-advanced', lessonId));
    }

    function practicePublicBankEnabled(programId, lessonId) {
      let bankId = programId + '__' + lessonId;
      return exists(/databases/$(database)/documents/practiceQuizPublicBanks/$(bankId))
        && get(/databases/$(database)/documents/practiceQuizPublicBanks/$(bankId)).data.enabled == true;
    }

    function practicePublicBankEnabledAny(programId, lessonId) {
      return practicePublicBankEnabled(programId, lessonId)
        || (programId == 'python-basic' && practicePublicBankEnabled('python-app-basic', lessonId))
        || (programId == 'python-app-basic' && practicePublicBankEnabled('python-basic', lessonId))
        || (programId == 'python-advanced' && practicePublicBankEnabled('python-app-advanced', lessonId))
        || (programId == 'python-app-advanced' && practicePublicBankEnabled('python-advanced', lessonId));
    }

    function quizPublicBankEnabledForBankId(bankId) {
      return exists(/databases/$(database)/documents/quizPublicQuestionBanks/$(bankId))
        && get(/databases/$(database)/documents/quizPublicQuestionBanks/$(bankId)).data.enabled == true;
    }

    function practicePublicBankEnabledForBankId(bankId) {
      return exists(/databases/$(database)/documents/practiceQuizPublicBanks/$(bankId))
        && get(/databases/$(database)/documents/practiceQuizPublicBanks/$(bankId)).data.enabled == true;
    }

    function storedQuizAnswerBank(bankId) {
      return get(/databases/$(database)/documents/quizQuestionBanks/$(bankId));
    }

    function isReadableQuizAnswerBank(bankId) {
      return exists(/databases/$(database)/documents/quizQuestionBanks/$(bankId))
        && (
          quizPublicBankEnabledForBankId(bankId)
          || (
            storedQuizAnswerBank(bankId).data.keys().hasAll(['programId', 'lessonId'])
            && quizPublicBankEnabledAny(
              storedQuizAnswerBank(bankId).data.programId,
              storedQuizAnswerBank(bankId).data.lessonId
            )
          )
        );
    }

    function storedPracticeAnswerBank(bankId) {
      return get(/databases/$(database)/documents/practiceQuizAnswerBanks/$(bankId));
    }

    function isReadablePracticeAnswerBank(bankId) {
      return exists(/databases/$(database)/documents/practiceQuizAnswerBanks/$(bankId))
        && (
          practicePublicBankEnabledForBankId(bankId)
          || (
            storedPracticeAnswerBank(bankId).data.keys().hasAll(['programId', 'lessonId'])
            && practicePublicBankEnabledAny(
              storedPracticeAnswerBank(bankId).data.programId,
              storedPracticeAnswerBank(bankId).data.lessonId
            )
          )
        );
    }

    function isValidBoundedPercent(correct, total, percent) {
      return correct is int
        && total is int
        && correct >= 0
        && total >= 1
        && correct <= total
        && percent is int
        && percent >= 0
        && percent <= 100;
    }

    function isValidPublicPracticeScoreFields(data) {
      return data.gradingStatus == 'pending'
        ? (
          data.mcqCorrect is int
          && data.mcqCorrect == 0
          && data.mcqTotal is int
          && data.mcqTotal >= 1
          && data.mcqPercent is int
          && data.mcqPercent == 0
          && data.responses.size() == data.mcqTotal
        )
        : (
          isValidBoundedPercent(data.mcqCorrect, data.mcqTotal, data.mcqPercent)
          && data.responses.size() == data.mcqTotal
        );
    }

    function isValidPublicQuizScoreFields(data) {
      return data.gradingStatus == 'pending'
        ? (
          data.mcqTotal is int
          && data.mcqTotal >= 0
          && data.mcqCorrect is int
          && data.mcqCorrect == 0
          && data.mcqPercent is int
          && data.mcqPercent == 0
          && data.codeGraded is int
          && data.codeGraded == 0
          && data.codeCorrect is int
          && data.codeCorrect == 0
          && data.gradedTotal is int
          && data.gradedTotal == 0
          && data.gradedCorrect is int
          && data.gradedCorrect == 0
          && data.gradedPercent is int
          && data.gradedPercent == 0
          && data.unansweredCount is int
          && data.unansweredCount >= 0
        )
        : (
          data.mcqTotal is int
          && data.mcqTotal >= 0
          && data.mcqCorrect is int
          && data.mcqCorrect >= 0
          && data.mcqCorrect <= data.mcqTotal
          && data.mcqPercent is int
          && data.mcqPercent >= 0
          && data.mcqPercent <= 100
          && data.codeGraded is int
          && data.codeGraded >= 0
          && data.codeCorrect is int
          && data.codeCorrect >= 0
          && data.codeCorrect <= data.codeGraded
          && data.gradedTotal is int
          && data.gradedTotal >= 0
          && data.gradedCorrect is int
          && data.gradedCorrect >= 0
          && data.gradedCorrect <= data.gradedTotal
          && data.gradedPercent is int
          && data.gradedPercent >= 0
          && data.gradedPercent <= 100
          && data.unansweredCount is int
          && data.unansweredCount >= 0
        );
    }

    function isQuizEnabledForLesson(data) {
      return data.programId is string
        && data.programId.size() > 0
        && data.lessonId is string
        && data.lessonId.size() > 0
        && quizPublicBankEnabledAny(data.programId, data.lessonId);
    }

    function isOpenQuizTarget(data) {
      return isOpenKnowledgeFeedbackTarget(data)
        && isQuizEnabledForLesson(data);
    }

    function isPracticeEnabledForLesson(data) {
      return data.programId is string
        && data.programId.size() > 0
        && data.lessonId is string
        && data.lessonId.size() > 0
        && practicePublicBankEnabledAny(data.programId, data.lessonId);
    }

    function isOpenPracticeTarget(data) {
      return isOpenKnowledgeFeedbackTarget(data)
        && isPracticeEnabledForLesson(data);
    }

    function isPracticeSubmissionId(submissionId, data) {
      return submissionId is string
        && data.submissionId == submissionId
        && data.classCode is string
        && data.studentId is string
        && data.lessonId is string
        && submissionId == data.classCode + '__' + data.studentId + '__' + data.lessonId;
    }

    function isValidPublicPracticeSubmissionWrite(submissionId) {
      return isPracticeSubmissionId(submissionId, request.resource.data)
        && isOpenClass(request.resource.data.classCode)
        && isActiveStudentInClass(request.resource.data.studentId, request.resource.data.classCode)
        && studentDoc(request.resource.data.studentId).data.fullName == request.resource.data.studentName
        && isOpenPracticeTarget(request.resource.data)
        && request.resource.data.responses is list
        && request.resource.data.responses.size() > 0
        && request.resource.data.gradingStatus in ['pending', 'complete']
        && isValidPublicPracticeScoreFields(request.resource.data)
        && request.resource.data.source == 'practice-quiz-v1'
        && request.resource.data.submittedAt == request.time
        && request.resource.data.updatedAt == request.time;
    }

    function quizAttemptAfter(attemptId) {
      return getAfter(/databases/$(database)/documents/quizAttempts/$(attemptId));
    }

    function hasMatchingQuizAttemptAfter(attemptId, data) {
      return quizAttemptAfter(attemptId).data != null
        && quizAttemptAfter(attemptId).data.attemptId == data.attemptId
        && quizAttemptAfter(attemptId).data.classCode == data.classCode
        && quizAttemptAfter(attemptId).data.studentId == data.studentId
        && quizAttemptAfter(attemptId).data.submittedAt == data.submittedAt;
    }

    function isValidPublicQuizAttemptCreate(attemptId) {
      return isQuizAttemptId(attemptId, request.resource.data)
        && isOpenClass(request.resource.data.classCode)
        && isActiveStudentInClass(request.resource.data.studentId, request.resource.data.classCode)
        && studentDoc(request.resource.data.studentId).data.fullName == request.resource.data.studentName
        && isOpenQuizTarget(request.resource.data)
        && request.resource.data.programId is string
        && request.resource.data.programId.size() > 0
        && request.resource.data.answers is map
        && request.resource.data.answers.size() > 0
        && request.resource.data.submittedAt == request.time
        && request.resource.data.createdAt == request.time;
    }

    function isReadableQuizAttemptReceipt(receiptId, data) {
      return data != null
        && isQuizAttemptId(receiptId, data)
        && isOpenClass(data.classCode)
        && isActiveStudentInClass(data.studentId, data.classCode);
    }

    function isValidPublicQuizAttemptReceiptCreate(receiptId) {
      return isQuizAttemptId(receiptId, request.resource.data)
        && isOpenClass(request.resource.data.classCode)
        && isActiveStudentInClass(request.resource.data.studentId, request.resource.data.classCode)
        && isOpenQuizTarget(request.resource.data)
        && request.resource.data.submittedAt == request.time
        && request.resource.data.createdAt == request.time
        && hasMatchingQuizAttemptAfter(receiptId, request.resource.data);
    }

    function isQuizLatestId(latestId, data) {
      return latestId is string
        && data.classCode is string
        && data.studentId is string
        && data.lessonId is string
        && latestId == data.classCode + '__' + data.studentId + '__' + data.lessonId;
    }

    function isReadableQuizLatest(latestId, data) {
      return data != null
        && isQuizLatestId(latestId, data)
        && isOpenClass(data.classCode)
        && isActiveStudentInClass(data.studentId, data.classCode);
    }

    function quizPublicBankDoc(programId, lessonId) {
      return get(/databases/$(database)/documents/quizPublicQuestionBanks/$(programId + '__' + lessonId));
    }

    function effectiveQuizMaxAttempts(programId, lessonId) {
      let bank = quizPublicBankDoc(programId, lessonId);
      return bank.data != null
        && bank.data.maxAttempts is int
        && bank.data.maxAttempts >= 1
        ? bank.data.maxAttempts
        : (bank.data != null && bank.data.allowRetake == false ? 1 : 3);
    }

    function currentQuizAttemptCount(classCode, studentId, lessonId) {
      let latestId = classCode + '__' + studentId + '__' + lessonId;
      let latestPath = /databases/$(database)/documents/studentQuizLatest/$(latestId);
      return exists(latestPath) && get(latestPath).data.attemptNumber is int
        ? get(latestPath).data.attemptNumber
        : 0;
    }

    function isValidQuizAttemptNumber(data) {
      return data.attemptNumber is int
        && data.attemptNumber == currentQuizAttemptCount(data.classCode, data.studentId, data.lessonId) + 1
        && data.attemptNumber <= effectiveQuizMaxAttempts(data.programId, data.lessonId);
    }

    function isValidPublicQuizSubmissionCreate() {
      return request.resource.data.classCode is string
        && request.resource.data.studentId is string
        && request.resource.data.lessonId is string
        && request.resource.data.studentName is string
        && request.resource.data.programId is string
        && request.resource.data.programId.size() > 0
        && isOpenClass(request.resource.data.classCode)
        && isActiveStudentInClass(request.resource.data.studentId, request.resource.data.classCode)
        && studentDoc(request.resource.data.studentId).data.fullName == request.resource.data.studentName
        && isOpenQuizTarget(request.resource.data)
        && request.resource.data.responses is list
        && request.resource.data.responses.size() > 0
        && request.resource.data.gradingStatus == 'pending'
        && isValidPublicQuizScoreFields(request.resource.data)
        && isValidQuizAttemptNumber(request.resource.data)
        && request.resource.data.source == 'student-quiz-v2'
        && request.resource.data.submittedAt == request.time
        && request.resource.data.createdAt == request.time;
    }

    function isValidQuizLatestScoreSummary(data) {
      return data.mcqTotal is int
        && data.mcqTotal >= 0
        && data.mcqCorrect is int
        && data.mcqCorrect >= 0
        && data.mcqCorrect <= data.mcqTotal
        && data.mcqPercent is int
        && data.mcqPercent >= 0
        && data.mcqPercent <= 100
        && data.codeGraded is int
        && data.codeGraded >= 0
        && data.codeCorrect is int
        && data.codeCorrect >= 0
        && data.codeCorrect <= data.codeGraded
        && data.gradedTotal is int
        && data.gradedTotal >= 0
        && data.gradedCorrect is int
        && data.gradedCorrect >= 0
        && data.gradedCorrect <= data.gradedTotal
        && data.gradedPercent is int
        && data.gradedPercent >= 0
        && data.gradedPercent <= 100
        && data.pendingCodeCount is int
        && data.pendingCodeCount >= 0
        && data.gradingStatus is string
        && data.gradingStatus in ['pending', 'partial', 'complete'];
    }

    function isValidPublicQuizLatestWrite(latestId) {
      return isQuizLatestId(latestId, request.resource.data)
        && isOpenClass(request.resource.data.classCode)
        && isActiveStudentInClass(request.resource.data.studentId, request.resource.data.classCode)
        && isOpenQuizTarget(request.resource.data)
        && request.resource.data.submissionId is string
        && request.resource.data.submissionId.size() > 0
        && isValidQuizAttemptNumber(request.resource.data)
        && request.resource.data.submittedAt == request.time;
    }

    function classUsesProjectNames(classId) {
      return classId is string
        && exists(/databases/$(database)/documents/classes/$(classId))
        && (!classDoc(classId).data.keys().hasAny(['finalMode']) || classDoc(classId).data.finalMode != 'exam');
    }

    function isValidPublicProjectNameSubmit(studentId) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'projectNameSubmission', 'projectNameStatus', 'projectNameReviewNote',
          'projectNameSubmittedAt', 'updatedAt'
        ])
        && resource.data.active == true
        && isOpenClass(resource.data.classId)
        && classUsesProjectNames(resource.data.classId)
        && (
          resource.data.projectNameStatus == ''
          || resource.data.projectNameStatus == 'rejected'
        )
        && request.resource.data.projectNameStatus == 'pending'
        && request.resource.data.projectNameSubmission is string
        && request.resource.data.projectNameSubmission.size() >= 3
        && request.resource.data.projectNameSubmission.size() <= 80
        && request.resource.data.projectNameReviewNote == ''
        && request.resource.data.projectNameSubmittedAt == request.time
        && request.resource.data.updatedAt == request.time;
    }

    function isValidPublicLessonProgressUpdate(studentId) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'lastOpenedLessonId', 'lastOpenedSessionNumber', 'lastOpenedAt',
          'openedLessonIds', 'updatedAt'
        ])
        && resource.data.active == true
        && isOpenClass(resource.data.classId)
        && request.resource.data.lastOpenedLessonId is string
        && request.resource.data.lastOpenedLessonId.size() > 0
        && request.resource.data.lastOpenedSessionNumber is number
        && request.resource.data.lastOpenedSessionNumber >= 1
        && request.resource.data.lastOpenedSessionNumber <= 50
        && request.resource.data.lastOpenedAt == request.time
        && request.resource.data.updatedAt == request.time
        && request.resource.data.openedLessonIds is list
        && request.resource.data.openedLessonIds.size() <= 200;
    }

    function reportClassCode(data) {
      return data.classCode is string ? data.classCode : data.classId;
    }

    function isReadableStudentReport(data) {
      return data != null
        && data.studentId is string
        && reportClassCode(data) is string
        && isOpenClass(reportClassCode(data))
        && isActiveStudentInClass(data.studentId, reportClassCode(data));
    }

    function isKnowledgeSummaryId(summaryId, data) {
      return summaryId is string
        && data.feedbackId == summaryId
        && data.classCode is string
        && data.studentId is string
        && data.lessonId is string
        && summaryId == data.classCode + '__' + data.studentId + '__' + data.lessonId;
    }

    function isReadableKnowledgeSummary(summaryId, data) {
      return data != null
        && isKnowledgeSummaryId(summaryId, data)
        && isOpenClass(data.classCode)
        && isActiveStudentInClass(data.studentId, data.classCode);
    }

    function isValidPublicKnowledgeSummaryCreate(summaryId) {
      return isKnowledgeSummaryId(summaryId, request.resource.data)
        && isOpenClass(request.resource.data.classCode)
        && isActiveStudentInClass(request.resource.data.studentId, request.resource.data.classCode)
        && isOpenKnowledgeFeedbackTarget(request.resource.data)
        && request.resource.data.understoodTopics is string
        && request.resource.data.understoodTopics.size() >= 5
        && request.resource.data.unclearTopics is string
        && request.resource.data.unclearTopics.size() >= 5
        && request.resource.data.understandingLevel is number
        && request.resource.data.understandingLevel >= 1
        && request.resource.data.understandingLevel <= 5
        && request.resource.data.supportRequest is string
        && request.resource.data.submittedAt == request.time;
    }

    function isValidPublicProjectLinksUpdate(studentId) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'projectGithubUrl', 'projectCanvaUrl', 'updatedAt'
        ])
        && resource.data.active == true
        && isOpenClass(resource.data.classId)
        && isValidOptionalProjectLink(request.resource.data.projectGithubUrl)
        && isValidOptionalProjectLink(request.resource.data.projectCanvaUrl)
        && request.resource.data.updatedAt == request.time;
    }

    function isFinalProjectClass(classCode) {
      return classCode is string
        && exists(/databases/$(database)/documents/classes/$(classCode))
        && classDoc(classCode).data.curriculumPhase == 'final'
        && (!classDoc(classCode).data.keys().hasAny(['finalMode']) || classDoc(classCode).data.finalMode != 'exam');
    }

    function isCodeSubmissionDocId(docId, data) {
      return docId is string
        && data.classCode is string
        && data.studentId is string
        && data.sessionNumber is number
        && docId == data.classCode + '__' + data.studentId + '__' + string(data.sessionNumber);
    }

    function isReadableCodeSubmission(docId, data) {
      return data != null
        && isCodeSubmissionDocId(docId, data)
        && isOpenClass(data.classCode)
        && isActiveStudentInClass(data.studentId, data.classCode);
    }

    function isValidCodeSubmissionFileMeta(entry) {
      return entry is map
        && entry.keys().hasOnly(['id', 'name', 'contentType', 'sizeBytes', 'uploadedAt'])
        && entry.id is string
        && entry.id.size() > 0
        && entry.name is string
        && entry.name.size() > 0
        && entry.name.size() <= 120
        && entry.contentType is string
        && entry.sizeBytes is number
        && entry.sizeBytes <= 524288
        && entry.uploadedAt is string;
    }

    function isValidCodeSubmissionWrite(docId) {
      return isCodeSubmissionDocId(docId, request.resource.data)
        && isOpenClass(request.resource.data.classCode)
        && isActiveStudentInClass(request.resource.data.studentId, request.resource.data.classCode)
        && isFinalProjectClass(request.resource.data.classCode)
        && studentDoc(request.resource.data.studentId).data.fullName == request.resource.data.studentName
        && studentDoc(request.resource.data.studentId).data.projectNameStatus == 'approved'
        && request.resource.data.sessionNumber >= 1
        && request.resource.data.sessionNumber <= 50
        && request.resource.data.files is list
        && request.resource.data.files.size() <= 10
        && request.resource.data.updatedAt == request.time;
    }

    function isValidCodeSubmissionContentWrite(docId, fileId) {
      return fileId is string
        && fileId.size() > 0
        && request.resource.data.keys().hasOnly(['content'])
        && request.resource.data.content is string
        && request.resource.data.content.size() <= 524288
        && exists(/databases/$(database)/documents/projectCodeSubmissions/$(docId))
        && isCodeSubmissionDocId(docId, get(/databases/$(database)/documents/projectCodeSubmissions/$(docId)).data)
        && isOpenClass(get(/databases/$(database)/documents/projectCodeSubmissions/$(docId)).data.classCode)
        && isActiveStudentInClass(
            get(/databases/$(database)/documents/projectCodeSubmissions/$(docId)).data.studentId,
            get(/databases/$(database)/documents/projectCodeSubmissions/$(docId)).data.classCode
          )
        && isFinalProjectClass(get(/databases/$(database)/documents/projectCodeSubmissions/$(docId)).data.classCode)
        && studentDoc(get(/databases/$(database)/documents/projectCodeSubmissions/$(docId)).data.studentId).data.projectNameStatus == 'approved';
    }

    function isValidCodeSubmissionContentDelete(docId, fileId) {
      return fileId is string
        && exists(/databases/$(database)/documents/projectCodeSubmissions/$(docId))
        && isReadableCodeSubmission(docId, get(/databases/$(database)/documents/projectCodeSubmissions/$(docId)).data);
    }

    function isValidPublicStudentSnapshotUpdate(studentId) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'currentProgressPercent', 'currentStage', 'currentStatus',
          'currentDifficulties', 'lastReportedAt', 'latestReportId',
          'progressStalledCount', 'projectGithubUrl', 'projectCanvaUrl',
          'updatedAt'
        ])
        && resource.data.active == true
        && isOpenClass(resource.data.classId)
        && isValidProgress(request.resource.data.currentProgressPercent)
        && isValidStage(request.resource.data.currentStage)
        && isValidStatus(request.resource.data.currentStatus)
        && request.resource.data.currentDifficulties is string
        && isValidOptionalProjectLink(request.resource.data.projectGithubUrl)
        && isValidOptionalProjectLink(request.resource.data.projectCanvaUrl)
        && request.resource.data.lastReportedAt == request.time
        && request.resource.data.updatedAt == request.time
        && request.resource.data.latestReportId is string
        && request.resource.data.latestReportId.size() > 0
        && existsAfter(/databases/$(database)/documents/reports/$(request.resource.data.latestReportId))
        && getAfter(/databases/$(database)/documents/reports/$(request.resource.data.latestReportId)).data.studentId == studentId
        && getAfter(/databases/$(database)/documents/reports/$(request.resource.data.latestReportId)).data.classCode == resource.data.classId
        && getAfter(/databases/$(database)/documents/reports/$(request.resource.data.latestReportId)).data.status == request.resource.data.currentStatus
        && getAfter(/databases/$(database)/documents/reports/$(request.resource.data.latestReportId)).data.stage == request.resource.data.currentStage
        && getAfter(/databases/$(database)/documents/reports/$(request.resource.data.latestReportId)).data.progressPercent == request.resource.data.currentProgressPercent;
    }

    // --- Collections ---

    match /admins/{adminId} {
      allow read: if isSignedIn() && adminId == normalizedEmail();
      allow write: if false;
    }

    match /classes/{classId} {
      allow read: if isAdmin() || (resource.data.status == 'active' && resource.data.hidden == false);
      allow write: if isAdmin();
    }

    match /minigameAttendance/{classCode} {
      allow read, write: if isAdmin();
    }

    match /curriculumPrograms/{programId} {
      allow read: if isAdmin() || resource.data.active == true;
      allow write: if isAdmin();

      match /lessons/{lessonId} {
        allow read: if isAdmin() || isActiveProgram(programId);
        allow write: if isAdmin();
      }
    }

    function isStudentFeedbackIndexId(indexId) {
      return indexId is string
        && indexId.size() > 0
        && indexId.matches('^.+__.+$');
    }

    function isReadableStudentFeedbackIndex(indexId, data) {
      return data != null
        && data.classCode is string
        && data.studentId is string
        && indexId == data.classCode + '__' + data.studentId
        && isOpenClass(data.classCode)
        && isActiveStudentInClass(data.studentId, data.classCode);
    }

    function isValidStudentFeedbackIndexWrite(indexId) {
      return isStudentFeedbackIndexId(indexId)
        && request.resource.data.classCode is string
        && request.resource.data.studentId is string
        && indexId == request.resource.data.classCode + '__' + request.resource.data.studentId
        && isOpenClass(request.resource.data.classCode)
        && isActiveStudentInClass(request.resource.data.studentId, request.resource.data.classCode)
        && request.resource.data.lessonIds is list;
    }

    match /studentFeedbackIndex/{indexId} {
      allow get: if isAdmin()
        || isReadableStudentFeedbackIndex(indexId, resource.data);
      allow list: if isAdmin();
      allow create, update: if isAdmin() || isValidStudentFeedbackIndexWrite(indexId);
      allow delete: if isAdmin();
    }

    match /students/{studentId} {
      allow read: if isAdmin() || resource.data.active == true;
      allow create: if isAdmin();
      allow update: if isAdmin()
        || isValidPublicStudentSnapshotUpdate(studentId)
        || isValidPublicProjectLinksUpdate(studentId)
        || isValidPublicProjectNameSubmit(studentId)
        || isValidPublicLessonProgressUpdate(studentId);
      allow delete: if isAdmin();
    }

    match /reports/{reportId} {
      allow get: if isAdmin() || isReadableStudentReport(resource.data);
      allow list: if isAdmin() || isReadableStudentReport(resource.data);
      allow create: if isAdmin() || isValidPublicReportCreate();
      allow update, delete: if isAdmin();
    }

    match /projectCodeSubmissions/{docId} {
      allow get: if isAdmin() || isReadableCodeSubmission(docId, resource.data);
      allow list: if isAdmin() || isReadableCodeSubmission(docId, resource.data);
      allow create, update: if isAdmin() || isValidCodeSubmissionWrite(docId);
      allow delete: if isAdmin() || isReadableCodeSubmission(docId, resource.data);

      match /files/{fileId} {
        allow get: if isAdmin() || isReadableCodeSubmission(
            docId,
            get(/databases/$(database)/documents/projectCodeSubmissions/$(docId)).data
          );
        allow create: if isAdmin() || isValidCodeSubmissionContentWrite(docId, fileId);
        allow delete: if isAdmin() || isValidCodeSubmissionContentDelete(docId, fileId);
        allow update: if false;
      }
    }

    match /knowledgeReportStudentSummaries/{summaryId} {
      allow get: if isAdmin() || isReadableKnowledgeSummary(summaryId, resource.data);
      allow list: if isAdmin() || isReadableKnowledgeSummary(summaryId, resource.data);
      allow create: if isAdmin() || isValidPublicKnowledgeSummaryCreate(summaryId);
      allow update, delete: if isAdmin();
    }

    match /knowledgeReports/{reportId} {
      allow read: if isAdmin();
      allow create: if isAdmin() || isValidPublicKnowledgeReportCreate(reportId);
      allow update, delete: if isAdmin();
    }

    match /knowledgeReportReceipts/{receiptId} {
      allow get: if isAdmin()
        || (isKnowledgeReceiptIdShape(receiptId) && isReadablePublicKnowledgeReportReceipt(receiptId, resource.data));
      allow list: if isAdmin();
      allow create: if isAdmin() || isValidPublicKnowledgeReportReceiptCreate(receiptId);
      allow update, delete: if isAdmin();
    }

    match /curriculumPrograms/{programId}/quizConfigs/{quizId} {
      allow read, write: if isAdmin();
    }
    match /curriculumPrograms/{programId}/quizPublicConfigs/{quizId} {
      allow read, write: if isAdmin();
    }
    match /quizQuestionBanks/{bankId} {
      allow get, list: if isAdmin();
      allow write: if isAdmin();
    }
    match /quizPublicQuestionBanks/{bankId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /quizLiveAttempts/{liveAttemptId} {
      allow read, write: if isAdmin();
    }
    match /quizAttempts/{attemptId} {
      allow read: if isAdmin();
      allow create: if isAdmin() || isValidPublicQuizAttemptCreate(attemptId);
      allow update, delete: if isAdmin();
    }
    match /quizAttemptReceipts/{receiptId} {
      allow get: if isAdmin()
        || (isKnowledgeReceiptIdShape(receiptId) && isReadableQuizAttemptReceipt(receiptId, resource.data));
      allow list: if isAdmin();
      allow create: if isAdmin() || isValidPublicQuizAttemptReceiptCreate(receiptId);
      allow update, delete: if isAdmin();
    }
    match /quizAttemptStates/{attemptId} {
      allow read, write: if isAdmin();
    }
    match /quizAttemptSubmissions/{attemptSubmissionId} {
      allow read, write: if isAdmin();
    }
    match /studentQuizSubmissions/{submissionId} {
      allow read: if isAdmin();
      allow create: if isAdmin() || isValidPublicQuizSubmissionCreate();
      allow update, delete: if isAdmin();
    }
    match /studentQuizLatest/{latestId} {
      allow get: if isAdmin()
        || (isKnowledgeReceiptIdShape(latestId) && isReadableQuizLatest(latestId, resource.data));
      allow list: if isAdmin();
      allow create, update: if isAdmin() || isValidPublicQuizLatestWrite(latestId);
      allow delete: if isAdmin();
    }
    match /practiceQuizPublicBanks/{bankId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /practiceQuizAnswerBanks/{bankId} {
      allow get: if isAdmin() || isReadablePracticeAnswerBank(bankId);
      allow list: if isAdmin();
      allow write: if isAdmin();
    }
    match /practiceQuizSubmissions/{submissionId} {
      allow get: if isAdmin()
        || (isKnowledgeReceiptIdShape(submissionId) && isPracticeSubmissionId(submissionId, resource.data)
          && isOpenClass(resource.data.classCode)
          && isActiveStudentInClass(resource.data.studentId, resource.data.classCode));
      allow list: if isAdmin();
      allow create, update: if isAdmin() || isValidPublicPracticeSubmissionWrite(submissionId);
      allow delete: if isAdmin();
    }

    function olympiaSessionDoc(sessionId) {
      return get(/databases/$(database)/documents/olympiaSessions/$(sessionId));
    }

    function isReadableOlympiaSession(sessionId) {
      return exists(/databases/$(database)/documents/olympiaSessions/$(sessionId))
        && isOpenClass(olympiaSessionDoc(sessionId).data.classCode);
    }

    function isOlympiaJoinableStatus(status) {
      return status == 'lobby' || status == 'playing' || status == 'reveal';
    }

    function isOlympiaSessionPlaying(sessionId) {
      return olympiaSessionDoc(sessionId).data.status == 'playing';
    }

    function isValidOlympiaRound(round) {
      return round == 'startup' || round == 'acceleration' || round == 'finish';
    }

    function isOlympiaResponseId(responseId, data) {
      return responseId is string
        && data.studentId is string
        && isValidOlympiaRound(data.round)
        && data.questionIndex is int
        && data.questionIndex >= 0
        && responseId == data.studentId + '__' + data.round + '__' + string(data.questionIndex);
    }

    function isValidOlympiaParticipantCreate(sessionId, studentId) {
      return isReadableOlympiaSession(sessionId)
        && isOlympiaJoinableStatus(olympiaSessionDoc(sessionId).data.status)
        && request.resource.data.keys().hasOnly([
          'studentName', 'joinedAt', 'totalScore', 'mountainStep', 'peakAt', 'lastActiveAt'
        ])
        && request.resource.data.studentName is string
        && request.resource.data.studentName.size() > 0
        && studentDoc(studentId).data.fullName == request.resource.data.studentName
        && isActiveStudentInClass(studentId, olympiaSessionDoc(sessionId).data.classCode)
        && request.resource.data.totalScore == 0
        && request.resource.data.mountainStep == 0
        && request.resource.data.peakAt == null;
    }

    function isValidOlympiaResponseCreate(sessionId, responseId) {
      return isOlympiaSessionPlaying(sessionId)
        && isOpenClass(olympiaSessionDoc(sessionId).data.classCode)
        && isActiveStudentInClass(request.resource.data.studentId, olympiaSessionDoc(sessionId).data.classCode)
        && studentDoc(request.resource.data.studentId).data.fullName == request.resource.data.studentName
        && isOlympiaResponseId(responseId, request.resource.data)
        && request.resource.data.round == olympiaSessionDoc(sessionId).data.currentRound
        && request.resource.data.questionIndex == olympiaSessionDoc(sessionId).data.questionIndex
        && request.resource.data.questionId is string
        && request.resource.data.questionId.size() > 0
        && request.resource.data.selectedOption is int
        && request.resource.data.selectedOption >= 0
        && request.resource.data.selectedOption <= 3
        && request.resource.data.isCorrect == null
        && request.resource.data.pointsEarned == 0
        && request.resource.data.responseMs is int
        && request.resource.data.responseMs >= 0
        && request.resource.data.answeredAt == request.time
        && (
          request.resource.data.round != 'finish'
          || (
            request.resource.data.finishChoice is int
            && (
              request.resource.data.finishChoice == 10
              || request.resource.data.finishChoice == 20
              || request.resource.data.finishChoice == 30
            )
          )
        )
        && (
          request.resource.data.round == 'finish'
          || request.resource.data.finishChoice == null
        );
    }

    function isOlympiaResponseReadable(sessionId) {
      return olympiaSessionDoc(sessionId).data.status == 'reveal'
        || olympiaSessionDoc(sessionId).data.status == 'finished';
    }

    match /olympiaSessions/{sessionId} {
      allow read: if isAdmin() || isReadableOlympiaSession(sessionId);
      allow create, update, delete: if isAdmin();

      match /participants/{studentId} {
        allow read: if isAdmin() || isReadableOlympiaSession(sessionId);
        allow create: if isAdmin() || isValidOlympiaParticipantCreate(sessionId, studentId);
        allow update, delete: if isAdmin();
      }

      match /responses/{responseId} {
        allow get: if isAdmin()
          || (isReadableOlympiaSession(sessionId) && isOlympiaResponseReadable(sessionId));
        allow list: if isAdmin();
        allow create: if isAdmin() || isValidOlympiaResponseCreate(sessionId, responseId);
        allow update, delete: if isAdmin();
      }
    }

    match /olympiaAnswerKeys/{sessionId} {
      allow read, write: if isAdmin();
    }

    function showdownSessionDoc(sessionId) {
      return get(/databases/$(database)/documents/showdownSessions/$(sessionId));
    }

    function isReadableShowdownSession(sessionId) {
      return exists(/databases/$(database)/documents/showdownSessions/$(sessionId))
        && isOpenClass(showdownSessionDoc(sessionId).data.classCode);
    }

    function isShowdownJoinableStatus(status) {
      return status == 'lobby' || status == 'playing' || status == 'reveal';
    }

    function isShowdownSessionPlaying(sessionId) {
      return showdownSessionDoc(sessionId).data.status == 'playing';
    }

    function isValidShowdownRound(round) {
      return round == 'startup' || round == 'obstacle' || round == 'finish';
    }

    function isShowdownResponseId(responseId, data) {
      return responseId is string
        && data.studentId is string
        && isValidShowdownRound(data.round)
        && data.questionIndex is int
        && data.questionIndex >= 0
        && responseId == data.studentId + '__' + data.round + '__' + string(data.questionIndex);
    }

    function isValidShowdownParticipantCreate(sessionId, studentId) {
      return isReadableShowdownSession(sessionId)
        && isShowdownJoinableStatus(showdownSessionDoc(sessionId).data.status)
        && request.resource.data.keys().hasOnly([
          'studentName', 'joinedAt', 'totalScore', 'lastActiveAt'
        ])
        && request.resource.data.studentName is string
        && request.resource.data.studentName.size() > 0
        && studentDoc(studentId).data.fullName == request.resource.data.studentName
        && isActiveStudentInClass(studentId, showdownSessionDoc(sessionId).data.classCode)
        && request.resource.data.totalScore == 0;
    }

    function isValidShowdownResponseCreate(sessionId, responseId) {
      return isShowdownSessionPlaying(sessionId)
        && showdownSessionDoc(sessionId).data.roundMode != 'oral'
        && isOpenClass(showdownSessionDoc(sessionId).data.classCode)
        && isActiveStudentInClass(request.resource.data.studentId, showdownSessionDoc(sessionId).data.classCode)
        && studentDoc(request.resource.data.studentId).data.fullName == request.resource.data.studentName
        && isShowdownResponseId(responseId, request.resource.data)
        && request.resource.data.round == showdownSessionDoc(sessionId).data.currentRound
        && request.resource.data.questionIndex == showdownSessionDoc(sessionId).data.questionIndex
        && request.resource.data.questionId is string
        && request.resource.data.questionId.size() > 0
        && (
          (
            request.resource.data.selectedOption is int
            && request.resource.data.selectedOption >= 0
            && request.resource.data.selectedOption <= 3
          )
          || (
            request.resource.data.textAnswer is string
            && request.resource.data.textAnswer.size() > 0
          )
        )
        && request.resource.data.isCorrect == null
        && request.resource.data.pointsEarned == 0
        && request.resource.data.responseMs is int
        && request.resource.data.responseMs >= 0
        && request.resource.data.answeredAt == request.time
        && (
          request.resource.data.round != 'finish'
          || (
            showdownSessionDoc(sessionId).data.activeStudentId == request.resource.data.studentId
            && request.resource.data.finishChoice is int
            && (
              request.resource.data.finishChoice == 10
              || request.resource.data.finishChoice == 20
              || request.resource.data.finishChoice == 30
            )
          )
        )
        && (
          request.resource.data.round == 'finish'
          || request.resource.data.finishChoice == null
        );
    }

    function isShowdownResponseReadable(sessionId) {
      return showdownSessionDoc(sessionId).data.status == 'reveal'
        || showdownSessionDoc(sessionId).data.status == 'finished';
    }

    match /showdownSessions/{sessionId} {
      allow read: if isAdmin() || isReadableShowdownSession(sessionId);
      allow create, update, delete: if isAdmin();

      match /participants/{studentId} {
        allow read: if isAdmin() || isReadableShowdownSession(sessionId);
        allow create: if isAdmin() || isValidShowdownParticipantCreate(sessionId, studentId);
        allow update, delete: if isAdmin();
      }

      match /responses/{responseId} {
        allow get: if isAdmin()
          || (isReadableShowdownSession(sessionId) && isShowdownResponseReadable(sessionId));
        allow list: if isAdmin();
        allow create: if isAdmin() || isValidShowdownResponseCreate(sessionId, responseId);
        allow update, delete: if isAdmin();
      }
    }

    match /showdownAnswerKeys/{sessionId} {
      allow read, write: if isAdmin();
    }

    match /showdownQuestions/{questionId} {
      allow read, write: if isAdmin();
    }

    match /showdownMatrices/{matrixId} {
      allow read, write: if isAdmin();
    }

    function spySessionDoc(sessionId) {
      return get(/databases/$(database)/documents/spySessions/$(sessionId));
    }

    function isReadableSpySession(sessionId) {
      return exists(/databases/$(database)/documents/spySessions/$(sessionId))
        && isOpenClass(spySessionDoc(sessionId).data.classCode);
    }

    function isSpyLobby(sessionId) {
      return spySessionDoc(sessionId).data.status == 'lobby';
    }

    function isSpyVotePhase(sessionId) {
      return spySessionDoc(sessionId).data.status == 'vote';
    }

    function isSpyPresentStudent(sessionId, studentId) {
      return studentId is string
        && spySessionDoc(sessionId).data.presentStudentIds is list
        && studentId in spySessionDoc(sessionId).data.presentStudentIds;
    }

    function isValidSpyParticipantCreate(sessionId, studentId) {
      return isSpyLobby(sessionId)
        && isOpenClass(spySessionDoc(sessionId).data.classCode)
        && isActiveStudentInClass(studentId, spySessionDoc(sessionId).data.classCode)
        && isSpyPresentStudent(sessionId, studentId)
        && request.resource.data.keys().hasOnly([
          'studentName', 'joinedAt', 'assignedWord', 'isSpy'
        ])
        && request.resource.data.studentName is string
        && request.resource.data.studentName.size() > 0
        && studentDoc(studentId).data.fullName == request.resource.data.studentName
        && request.resource.data.assignedWord == ''
        && request.resource.data.isSpy == false
        && request.resource.data.joinedAt == request.time;
    }

    function isValidSpyVoteCreate(sessionId, voterId) {
      return isSpyVotePhase(sessionId)
        && isOpenClass(spySessionDoc(sessionId).data.classCode)
        && isActiveStudentInClass(voterId, spySessionDoc(sessionId).data.classCode)
        && isSpyPresentStudent(sessionId, voterId)
        && request.resource.data.keys().hasOnly(['targetStudentId', 'votedAt'])
        && request.resource.data.targetStudentId is string
        && request.resource.data.targetStudentId.size() > 0
        && request.resource.data.targetStudentId != voterId
        && isSpyPresentStudent(sessionId, request.resource.data.targetStudentId)
        && request.resource.data.votedAt == request.time
        && !exists(/databases/$(database)/documents/spySessions/$(sessionId)/votes/$(voterId));
    }

    match /spySessions/{sessionId} {
      allow read: if isAdmin() || isReadableSpySession(sessionId);
      allow create, update, delete: if isAdmin();

      match /participants/{studentId} {
        allow read: if isAdmin() || isReadableSpySession(sessionId);
        allow create: if isAdmin() || isValidSpyParticipantCreate(sessionId, studentId);
        allow update, delete: if isAdmin();
      }

      match /votes/{voterId} {
        allow get: if isAdmin()
          || (isReadableSpySession(sessionId) && isSpyPresentStudent(sessionId, voterId));
        allow list: if isAdmin() || isReadableSpySession(sessionId);
        allow create: if isAdmin() || isValidSpyVoteCreate(sessionId, voterId);
        allow update, delete: if isAdmin();
      }
    }
  }
}
